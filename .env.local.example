# Copy to .env.local and set your values

# Mapbox: get a token at https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here

# Qdrant Cloud: for vector search (POST /api/murals, POST /api/search). Get URL + API key from your cluster in Qdrant Cloud.
QDRANT_URL=https://your-cluster.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Supabase: canonical murals DB + storage for community uploads. Create project at https://supabase.com/
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Show "Check a mural" button (camera); set in Vercel to enable/disable. Omit or set to anything other than "true" to hide.
NEXT_PUBLIC_ENABLE_CHECK_MURAL=true

# Cloudflare Turnstile (invisible): verify community submissions. Get keys at https://dash.cloudflare.com/ -> Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
